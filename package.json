{
  "name": "resq-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server/index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm:server\" \"npm:client\"",
    "client": "vite --host 0.0.0.0",
    "server": "tsx watch --env-file-if-exists=.env src/server/index.ts",
    "start": "tsx --env-file-if-exists=.env src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build && node scripts/build-server.mjs",
    "db:push": "tsx --env-file-if-exists=.env src/server/db/applySchema.ts"
  },
  "keywords": [],
  "author": "ResQ",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase": "^12.16.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.11.0",
    "multer": "^2.1.1",
    "onnxruntime-web": "^1.24.3",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "twilio": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
