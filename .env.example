PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Neon/Postgres connection string. The demo runs in memory when this is empty.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Optional DWG converter command. Leave empty for upload-only DWG support.
# Example shape for a wrapper script: DWG_CONVERTER_COMMAND=C:\tools\dwg-to-dxf.ps1
DWG_CONVERTER_COMMAND=

# Server-only Gemini API key. Do not expose this with a VITE_ prefix.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Public Hugging Face model repo used when local ONNX files are absent.
HF_MODEL_BASE_URL=https://huggingface.co/Snaptrope/resq/resolve/main

# Browser Google Maps JavaScript API key with Maps JavaScript, Places, and Directions enabled.
VITE_GOOGLE_MAPS_API_KEY=

# Twilio credentials for SMS / WhatsApp hazard alerts.
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Your Twilio phone number (for SMS), e.g. +15017122661
TWILIO_PHONE_NUMBER=
# WhatsApp sender — use Twilio sandbox number or your approved WhatsApp number
# Sandbox default: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
